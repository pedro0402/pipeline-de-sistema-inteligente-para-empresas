#!/usr/bin/env sh
set -eu

staged_files="$(git diff --cached --name-only --diff-filter=ACMR)"

# Nothing staged, nothing to validate.
[ -z "$staged_files" ] && exit 0

# Python code changes outside tests require documentation updates.
python_changed="$(printf '%s\n' "$staged_files" | grep -E '^backend/.*\.py$' | grep -Ev '^backend/tests/' || true)"

[ -z "$python_changed" ] && exit 0

docs_changed="$(printf '%s\n' "$staged_files" | grep -E '^(README\.md|CHANGELOG\.md|docs/.*\.md|backend/.*\.md)$' || true)"

# Accept commits that include docstring additions/updates in changed Python files.
docstring_changed="$(git diff --cached -U0 -- $python_changed | grep -E "^\+[[:space:]]*('''|\"\"\")" || true)"

if [ -z "$docs_changed" ] && [ -z "$docstring_changed" ]; then
  echo ""
  echo "[pre-commit] Falha de documentacao automatica"
  echo "Mudancas de codigo Python detectadas sem documentacao correspondente."
  echo ""
  echo "Arquivos Python alterados:"
  printf '%s\n' "$python_changed" | sed 's/^/ - /'
  echo ""
  echo "Para continuar, faca ao menos uma das opcoes:"
  echo "  1) Atualize README.md, CHANGELOG.md, docs/*.md ou backend/*.md"
  echo "  2) Adicione/atualize docstrings nas funcoes/classes alteradas"
  echo ""
  exit 1
fi

exit 0
